# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic (LLM generation — used in every notebook)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings via text-embedding-3-small — used in every notebook)
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Cohere (reranking — used in modules 02_advanced_rag, 21_modular_rag)
COHERE_API_KEY=

# Tavily (web search — used in module 17_corrective_rag)
TAVILY_API_KEY=

# ── Local settings (no API needed) ───────────────────────────────────────────
# Set to "true" to activate offline/mock mode (pre-cached fixtures)
RAG_OFFLINE_MODE=false

# ChromaDB persistence directory (default: ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db
